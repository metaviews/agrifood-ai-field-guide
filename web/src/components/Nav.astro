---
const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path.startsWith(href);
};
const links = [
  { href: '/', label: 'Home' },
  { href: '/units/', label: 'Units' },
  { href: '/scans/', label: 'Scans' },
  { href: '/talks/', label: 'Talks' },
  { href: '/archetypes/', label: 'Archetypes' },
  { href: '/quotes/', label: 'Quotes' },
];
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-title">Agrifood AI Field Guide</a>
    <ul class="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
        </li>
      ))}
      <li>
        <a href="/search" class={isActive('/search') ? 'active' : ''}>Search</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    background: var(--cream-soft);
    border-bottom: 1px solid var(--rule);
    padding: 0.85rem 0;
  }
  .nav-inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .nav-title {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.005em;
  }
  .nav-title:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .nav-links a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }
  .nav-links a:hover {
    color: var(--ink);
    border-bottom-color: var(--rule);
  }
  .nav-links a.active {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }
</style>