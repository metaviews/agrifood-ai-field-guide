---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const units = await getCollection('units');
const scans = await getCollection('scans');
const quotes = await getCollection('quotes');
const allTalks = await getCollection('talks');
const archetypes = allTalks.filter((t) => t.data.archetype_number !== undefined);
---

<Base title="Agrifood AI Field Guide" cover={true} description="A working knowledge base on artificial intelligence in agrifood systems — concrete deployments, regional scans, talk methodology, and speaker voices.">
  <h1>Agrifood AI Field Guide</h1>

  <p>
    A working knowledge base on artificial intelligence in agrifood systems.
    Each unit documents a concrete AI deployment with named-source evidence;
    scans synthesise multiple units into regional or topic overviews;
    quotes carry the voices of named speakers.
  </p>

  <h2>Browse the corpus</h2>

  <div class="counts">
    <a href="/units/" class="count-card">
      <span class="count-num">{units.length}</span>
      <span class="count-label">units</span>
      <span class="count-desc">Concrete deployments of AI in agrifood, with sources.</span>
    </a>
    <a href="/scans/" class="count-card">
      <span class="count-num">{scans.length}</span>
      <span class="count-label">scans</span>
      <span class="count-desc">Regional or topic overviews drawing on multiple units.</span>
    </a>
    <a href="/quotes/" class="count-card">
      <span class="count-num">{quotes.length}</span>
      <span class="count-label">quotes</span>
      <span class="count-desc">Named speakers, verbatim and paraphrased.</span>
    </a>
    <a href="/talks/" class="count-card">
      <span class="count-num">{archetypes.length}</span>
      <span class="count-label">talk archetypes</span>
      <span class="count-desc">Repeatable talk-assembly patterns with named units and quotes, plus methodology docs.</span>
    </a>
  </div>

  <p class="about-link">
    The source repository is on
    <a href="https://github.com/metaviews/agrifood-ai-field-guide">GitHub</a>
    &mdash; including the
    <a href="https://github.com/metaviews/agrifood-ai-field-guide/blob/main/taxonomy/v5.md">taxonomy</a>,
    <a href="https://github.com/metaviews/agrifood-ai-field-guide/blob/main/VISION.md">project vision</a>,
    and contribution discipline.
  </p>

  <h2>About this resource</h2>
  <p>
    This knowledge base was assembled with the help of
    <a href="https://hermes-agent.nousresearch.com/docs">Hermes Agent</a>
    and <a href="https://nousresearch.com">MiniMax M3</a>. The corpus is
    maintained as a public open-source project; every unit, scan, quote,
    and archetype is released under
    <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>.
    Contributions, corrections, and additions are welcome via
    <a href="https://github.com/metaviews/agrifood-ai-field-guide/issues">GitHub issues</a>
    or pull requests.
  </p>
</Base>

<style>
  .counts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem;
    margin: 1.5rem 0 2rem 0;
  }
  .count-card {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    padding: 0.95rem 1rem;
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, background 0.15s;
  }
  .count-card:hover {
    border-color: var(--ink-soft);
    background: var(--cream-dark);
  }
  .count-num {
    font-size: 1.85rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }
  .count-label {
    font-size: 1rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  .count-desc {
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin-top: 0.3em;
  }
  .about-link {
    margin-top: 2rem;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
</style>