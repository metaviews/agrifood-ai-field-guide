---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { scanBucket, SCAN_BUCKET_ORDER } from '../../scan-buckets.ts';

const scans = await getCollection('scans');
scans.sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id));

// Group scans by bucket. Scans are regional or topic overviews, so the
// primary axis is geography and the secondary axis is theme.
const byBucket: Record<string, typeof scans> = {};
for (const bucket of SCAN_BUCKET_ORDER) {
  byBucket[bucket.id] = [];
}
for (const scan of scans) {
  const bucket = scanBucket(scan.id, scan.data.title);
  if (byBucket[bucket]) byBucket[bucket].push(scan);
}

function titleOf(s: typeof scans[number]): string {
  return s.data.title ?? s.id;
}

const toc = SCAN_BUCKET_ORDER.map((bucket) => ({
  id: bucket.id,
  label: bucket.label,
  count: byBucket[bucket.id].length,
}));
---

<Base title="Scans" description="Regional and topic scans synthesising multiple units on AI in agrifood.">
  <h1>Scans</h1>
  <p>
    Regional and topic scans that synthesise multiple units into a
    single overview. Each scan pulls together named units, named sources,
    and field observations from a particular geographic or thematic
    context.
  </p>

  <nav class="toc" aria-label="Bucket navigation">
    <h2>Browse by region or theme</h2>
    <ul>
      {toc.map((entry) => (
        <li>
          <a href={`#bucket-${entry.id}`}>
            <span class="toc-label">{entry.label}</span>
            <span class="toc-count">{entry.count}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {SCAN_BUCKET_ORDER.map((bucket) => {
    const list = byBucket[bucket.id];
    if (list.length === 0) return null;
    return (
      <section class="bucket" id={`bucket-${bucket.id}`}>
        <h2>{bucket.label} <span class="bucket-count">({list.length})</span></h2>
        <p class="bucket-desc">{bucket.description}</p>
        <ul class="bucket-list">
          {list.map((scan) => (
            <li>
              <a href={`/scans/${scan.id}/`}>{titleOf(scan)}</a>
              {scan.data.summary && <span class="bucket-summary"> — {scan.data.summary}</span>}
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Base>

<style>
  .toc {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 1.1rem 1.25rem;
    margin: 1.5rem 0 2.5rem 0;
  }
  .toc h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin: 0 0 0.6em 0;
    padding: 0;
    border: none;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.4rem 1rem;
  }
  .toc li a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--rule);
    padding: 0.25em 0;
  }
  .toc li a:hover {
    border-bottom-color: var(--ink);
  }
  .toc-label {
    font-size: 0.9rem;
  }
  .toc-count {
    color: var(--ink-faint);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  .bucket {
    margin: 2.5rem 0;
    scroll-margin-top: 1rem;
  }
  .bucket:first-of-type {
    margin-top: 1.5rem;
  }
  .bucket h2 {
    font-size: 1.4rem;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.25em;
    margin-bottom: 0.4em;
  }
  .bucket-count {
    font-size: 0.85rem;
    color: var(--ink-faint);
    font-weight: 400;
  }
  .bucket-desc {
    color: var(--ink-soft);
    font-size: 0.95rem;
    font-style: italic;
    margin: 0 0 0.85em 0;
  }
  .bucket-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .bucket-list li {
    padding: 0.35em 0;
    border-bottom: 1px dotted var(--rule);
    line-height: 1.5;
  }
  .bucket-list li:last-child {
    border-bottom: none;
  }
  .bucket-list a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .bucket-list a:hover {
    border-bottom-color: var(--ink-soft);
  }
  .bucket-summary {
    color: var(--ink-soft);
    font-size: 0.92em;
  }
</style>