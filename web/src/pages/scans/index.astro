---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const scans = await getCollection('scans');
scans.sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id));
---

<Base title="Scans" description="Regional or topic scans synthesising multiple units.">
  <h1>Scans</h1>
  <p>
    Synthesising scans — regional deep-dives or topic overviews that draw on
    multiple units and surface analytical observations across them.
  </p>
  {scans.map((scan) => {
    const title = scan.data.title ?? scan.id;
    return (
      <article class="entry">
        <h2><a href={`/scans/${scan.id}/`}>{title}</a></h2>
        <div class="meta">
          {scan.data.region && <span class="tag">{scan.data.region}</span>}
          {scan.data.date && <span class="tag">{scan.data.date}</span>}
        </div>
        {scan.data.summary && <p class="summary">{scan.data.summary}</p>}
      </article>
    );
  })}
</Base>

<style>
  .entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .entry h2 {
    margin: 0 0 0.3em 0;
    font-size: 1.25rem;
  }
  .entry h2 a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5em;
    font-size: 0.85rem;
  }
  .tag {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    padding: 0.1em 0.5em;
    border-radius: 2px;
    color: var(--ink-soft);
  }
  .summary {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0;
  }
</style>