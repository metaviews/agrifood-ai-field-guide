---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((q) => ({
    params: { slug: q.id },
    props: { quote: q },
  }));
}

const { quote: q } = Astro.props;
const { Content } = await render(q);
const title = q.data.title ?? q.id;
---

<Base title={title}>
  <nav class="back-link">
    <a href="/quotes/">&larr; All quotes</a>
  </nav>
  <h1>{title}</h1>
  <Content />
</Base>

<style>
  .back-link { font-size: 0.9rem; color: var(--ink-soft); margin-bottom: 1rem; }
  .meta { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5em; font-size: 0.85rem; }
  .tag {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    padding: 0.15em 0.55em;
    border-radius: 2px;
    color: var(--ink-soft);
  }
</style>