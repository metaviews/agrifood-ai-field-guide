---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const archetypes = await getCollection('archetypes');
archetypes.sort((a, b) => {
  const aN = a.data.archetype_number ?? 999;
  const bN = b.data.archetype_number ?? 999;
  return aN - bN;
});
---

<Base title="Archetypes" description="Repeatable talk-assembly patterns.">
  <h1>Archetypes</h1>
  <p>
    Repeatable talk-assembly patterns. Each archetype is a working spine: a
    documented way to assemble units, scans, and quotes into a talk for a
    specific audience and duration.
  </p>
  {archetypes.map((arch) => {
    const title = arch.data.title ?? arch.id;
    const num = arch.data.archetype_number;
    return (
      <article class="entry">
        <h2>
          {num !== undefined && <span class="num">{String(num).padStart(2, '0')}</span>}
          <a href={`/archetypes/${arch.id}/`}>{title}</a>
        </h2>
        <div class="meta">
          {arch.data.audience && <span class="tag">audience: {arch.data.audience}</span>}
          {arch.data.duration && <span class="tag">{arch.data.duration}</span>}
        </div>
        {arch.data.summary && <p class="summary">{arch.data.summary}</p>}
      </article>
    );
  })}
</Base>

<style>
  .entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .entry h2 {
    margin: 0 0 0.3em 0;
    font-size: 1.25rem;
    display: flex;
    align-items: baseline;
    gap: 0.6em;
  }
  .entry h2 a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .num {
    font-family: 'JetBrains Mono', Menlo, monospace;
    color: var(--ink-faint);
    font-size: 0.85em;
    font-weight: 400;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.5em;
    font-size: 0.85rem;
  }
  .tag {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    padding: 0.1em 0.5em;
    border-radius: 2px;
    color: var(--ink-soft);
  }
  .summary {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0;
  }
</style>