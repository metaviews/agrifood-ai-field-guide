---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const archetypes = await getCollection('archetypes');
  return archetypes.map((arch) => ({
    params: { slug: arch.id },
    props: { arch },
  }));
}

const { arch } = Astro.props;
const { Content } = await render(arch);
const title = arch.data.title ?? arch.id;
const num = arch.data.archetype_number;
---

<Base title={title} description={arch.data.summary ?? `Archetype: ${title}`}>
  <nav class="back-link">
    <a href="/archetypes/">&larr; All archetypes</a>
  </nav>
  <h1>
    {num !== undefined && <span class="num">{String(num).padStart(2, '0')}</span>}
    {title}
  </h1>
  <Content />
</Base>

<style>
  .back-link { font-size: 0.9rem; color: var(--ink-soft); margin-bottom: 1rem; }
  h1 { display: flex; align-items: baseline; gap: 0.5em; }
  .num {
    font-family: 'JetBrains Mono', Menlo, monospace;
    color: var(--ink-faint);
    font-size: 0.75em;
    font-weight: 400;
  }
  .meta { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5em; font-size: 0.85rem; }
  .tag {
    background: var(--cream-soft);
    border: 1px solid var(--rule);
    padding: 0.15em 0.55em;
    border-radius: 2px;
    color: var(--ink-soft);
  }
</style>