---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { parseArchetypeHeader } from '../../archetype-metadata.ts';

// The talks collection has two kinds of content:
//   - archetypes/  → the six working talk-assembly patterns (the public-facing spine)
//   - *.md at root → methodology and reference docs (taxonomy, index)
//
// The archetypes are what visitors come for. The methodology docs sit behind
// them as supporting infrastructure.

const archetypes = await getCollection('archetypes');
archetypes.sort((a, b) => (a.data.archetype_number ?? 999) - (b.data.archetype_number ?? 999));

const methodologyDocs = await getCollection('talks', (t) => !t.id.startsWith('archetypes/'));
methodologyDocs.sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id));

interface ArchetypeCard {
  num: number;
  id: string;
  title: string;
  spine: string;
  audience: string;
  duration: string;
  region: string;
  depth: string;
}

const cards: ArchetypeCard[] = archetypes.map((arch) => {
  const meta = parseArchetypeHeader((arch as any).body ?? '');
  return {
    num: arch.data.archetype_number ?? 0,
    id: arch.id,
    title: arch.data.title ?? arch.id,
    spine: meta.spine,
    audience: meta.audience,
    duration: meta.duration,
    region: meta.region,
    depth: meta.depth,
  };
});

function titleOf(t: typeof methodologyDocs[number]): string {
  return t.data.title ?? t.id;
}
---

<Base title="Talks" description="Six working talk archetypes for presenting AI in agrifood to different audiences.">
  <h1>Talks</h1>
  <p>
    Six working talk archetypes — repeatable ways to assemble the corpus
    into a presentation for a specific audience, duration, and analytical
    spine. Each archetype is a complete run-of-show with named units,
    named quotes, and substitutions for common contexts.
  </p>

  <section class="archetypes">
    {cards.map((card) => (
      <article class="archetype-card">
        <div class="card-numeral">{String(card.num).padStart(2, '0')}</div>
        <div class="card-body">
          <h2><a href={`/archetypes/${card.id}/`}>{card.title.replace(/^Archetype \d+\s*[—-]\s*/, '')}</a></h2>
          <dl class="card-meta">
            {card.spine && (
              <div class="meta-row">
                <dt>Spine</dt>
                <dd>{card.spine.replace(/\s*\(.*?\)\s*$/, '').trim()}</dd>
              </div>
            )}
            {card.duration && (
              <div class="meta-row">
                <dt>Duration</dt>
                <dd>{card.duration}</dd>
              </div>
            )}
            {card.audience && (
              <div class="meta-row">
                <dt>Audience</dt>
                <dd>{card.audience}</dd>
              </div>
            )}
            {card.region && (
              <div class="meta-row">
                <dt>Region</dt>
                <dd>{card.region}</dd>
              </div>
            )}
            {card.depth && (
              <div class="meta-row">
                <dt>Depth</dt>
                <dd>{card.depth}</dd>
              </div>
            )}
          </dl>
        </div>
      </article>
    ))}
  </section>

  <section class="methodology">
    <h2>Methodology</h2>
    <p>
      Reference and methodology material that supports the archetypes.
      The cluster-pattern taxonomy describes the recurring shape of
      regional agrifood-AI deployments; the talks index is the quick-reference
      table that previously lived in the corpus.
    </p>
    <ul class="methodology-list">
      {methodologyDocs.map((doc) => (
        <li>
          <a href={`/talks/${doc.id}/`}>{titleOf(doc)}</a>
          {doc.data.summary && <span class="meta-summary"> — {doc.data.summary}</span>}
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .archetypes {
    margin: 1.5rem 0 3rem 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .archetype-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .card-numeral {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 2.1rem;
    line-height: 1;
    color: var(--ink-faint);
    font-weight: 400;
    min-width: 3rem;
    text-align: right;
    padding-top: 0.15rem;
  }
  .card-body h2 {
    margin: 0 0 0.6rem 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }
  .card-body h2 a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .card-body h2 a:hover {
    border-bottom-color: var(--ink-soft);
  }
  .card-meta {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.25rem 1.25rem;
    font-size: 0.88rem;
  }
  .meta-row {
    display: contents;
  }
  .meta-row dt {
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    align-self: start;
    padding-top: 0.15em;
  }
  .meta-row dd {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.45;
  }

  .methodology {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .methodology h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin: 0 0 0.6em 0;
    border: none;
    padding: 0;
  }
  .methodology-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .methodology-list li {
    padding: 0.5em 0;
    border-bottom: 1px dotted var(--rule);
  }
  .methodology-list li:last-child {
    border-bottom: none;
  }
  .methodology-list a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .methodology-list a:hover {
    border-bottom-color: var(--ink-soft);
  }
  .meta-summary {
    color: var(--ink-soft);
    font-size: 0.92em;
  }

  @media (min-width: 720px) {
    .archetype-card {
      gap: 1.75rem;
      padding: 1.6rem 0;
    }
    .card-numeral {
      font-size: 2.4rem;
      min-width: 4rem;
    }
  }
</style>