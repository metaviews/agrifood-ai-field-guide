---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const units = await getCollection('units');
  return units.map((unit) => ({
    params: { slug: unit.id },
    props: { unit },
  }));
}

const { unit } = Astro.props;
const { Content } = await render(unit);
const title = unit.data.title ?? unit.id;
---

<Base title={title} description={unit.data.summary ?? `Unit: ${title}`}>
  <nav class="back-link">
    <a href="/units/">&larr; All units</a>
  </nav>
  <h1>{title}</h1>
  {unit.data.region && (
    <p class="unit-region">{unit.data.region}</p>
  )}
  <Content />
</Base>

<style>
  .back-link {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin-bottom: 1rem;
  }
  .unit-region {
    font-style: italic;
    color: var(--ink-soft);
    margin-top: -0.5em;
    margin-bottom: 1.5em;
    font-size: 0.95rem;
  }
</style>